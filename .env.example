# =============================================================================
# GitHub Uploader 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# =============================================================================

# -----------------------------------------------------------------------------
# 服务配置
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=production

# 资源下载目录（CLI工具使用）
DOWNLOADS_DIR=./downloads

# -----------------------------------------------------------------------------
# GitHub 配置
# -----------------------------------------------------------------------------
# GitHub Personal Access Token
# 获取方式: https://github.com/settings/tokens
# 需要的权限: repo (完全控制私有仓库)
GITHUB_TOKEN=ghp_your_token_here

# 默认仓库名称（可选）
DEFAULT_REPO_NAME=openclaw-resources

# -----------------------------------------------------------------------------
# 飞书应用配置
# -----------------------------------------------------------------------------
# 飞书 App ID
# 获取方式: https://open.feishu.cn/app -> 创建应用 -> 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx

# 飞书 App Secret
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书 Encrypt Key（事件订阅使用，可选）
FEISHU_ENCRYPT_KEY=

# 飞书 Verification Token（事件订阅使用，可选）
FEISHU_VERIFICATION_TOKEN=

# -----------------------------------------------------------------------------
# 资源下载配置（可选）
# -----------------------------------------------------------------------------
# 资源仓库地址
RESOURCES_REPO=4129163/openclaw-resources

# 资源版本标签
RESOURCES_TAG=latest
